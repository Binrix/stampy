{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-api",
            "type": "typescript",
            "tsconfig": "./stampy-api/tsconfig.json",
            "problemMatcher": {
                "owner": "typescript",
                "pattern": "$tsc",
                "background": {
                  "activeOnStart": true,
                  "beginsPattern": {
                    "regexp": "(.*?)"
                  },
                  "endsPattern": {
                    "regexp": "bundle generation complete"
                  }
                }
            },
            "group": "build"
        }
    ]
}